# Root-Config fuer das Backend-Modul.
config.stopBubbling = true

# Markiert Lombok-generierten Code mit @lombok.Generated. SpotBugs (und andere
# Bytecode-Analysen) ignorieren so generierte Methoden automatisch und fluten die
# Reports nicht. Siehe docs/quality/backend-code-qualitaet.md (Abschnitt Lombok).
lombok.addLombokGeneratedAnnotation = true
