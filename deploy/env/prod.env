# Nicht-geheime Laufzeit-Config für die PROD-Umgebung (fehmarn-open.de, Port 8080).
# Wird beim Deploy nach /opt/fehmarnopen/prod/config.env ausgerollt (siehe ci.yml, #143).
# Secrets stehen NICHT hier, sondern in secrets.env (beim Deploy aus GitHub Secrets injiziert).

# Spring nur lokal binden – von außen ist ausschließlich Caddy erreichbar (ADR 0010).
SERVER_ADDRESS=127.0.0.1
# Interner Port hinter dem Caddy-Reverse-Proxy (test = 8081, prod = 8080).
SERVER_PORT=8080
# Same-Origin (Frontend kommt aus dem JAR); als Absicherung explizit gesetzt.
CORS_ALLOWED_ORIGINS=https://fehmarn-open.de
# Admin-Anmeldenamen (nicht geheim; die Passwörter liegen als Environment-Secrets).
ADMIN_1_USERNAME=fl
ADMIN_2_USERNAME=ns
